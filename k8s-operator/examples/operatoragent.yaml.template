apiVersion: kubeagents.x-k8s.io/v1alpha1
kind: OperatorAgent
metadata:
  name: operator-agent-${TARGET_CLUSTER_NAME}-${TARGET_CLUSTER_LOCATION}
  namespace: ${NAMESPACE}
spec:
  harness:
    clusterName: "${TARGET_CLUSTER_NAME}"
    location: "${TARGET_CLUSTER_LOCATION}"
    hermes:
      apiServerSecretRef:
        name: "platform-agent-secrets"
        key: "API_SERVER_KEY"
  deployment:
    image: "${OPERATOR_AGENT_IMAGE}"
    tag: "latest"
  security:
    serviceAccountName: "operator-agent"
    workloadIdentity:
      gcp:
        gsaName: "operator-agent-gsa"
        projectId: "${PROJECT_ID}"
  model:
    provider: "gemini"
    default: "gemini-3.1-flash-lite"
    gemini:
      apiKeySecretRef:
        name: "platform-agent-secrets"
        key: "GEMINI_API_KEY"
