apiVersion: kubeagents.x-k8s.io/v1alpha1
kind: PlatformAgent
metadata:
  name: platform-agent
  namespace: "${NAMESPACE}"
spec:
  harness:
    clusterName: "${CLUSTER_NAME}"
    location: "${REGION}"
    openclaw:
      agentHome: "/opt/data"
      gatewayTokenSecretRef:
        name: platform-agent-secrets
        key: API_SERVER_KEY
  deployment:
    # runtimeClassName: gvisor # Uncomment to enable GKE Sandbox (gVisor) kernel isolation
    image: "${AGENT_IMAGE}"
    tag: "${AGENT_TAG}"
    imagePullPolicy: Always
  security:
    serviceAccountName: "${KSA_NAME}"
    serviceAccountAnnotations:
      iam.gke.io/gcp-service-account: "${GSA_NAME}@${PROJECT_ID}.iam.gserviceaccount.com"
  integration:
    github:
      gitRepo: "${GITHUB_FULL_REPO}"
    googleChat:
      enabled: ${GOOGLE_CHAT_ENABLED}
      mode: "${GOOGLE_CHAT_MODE}"
      projectId: "${PROJECT_ID}"
      allowedUsers:
        - "${ALLOWED_USERS}"
      homeChannel: ""
      appUrl: "${APP_URL}"
      appPrincipal: "${APP_PRINCIPAL}"
      domain: "${GOOGLE_CHAT_DOMAIN}"
      autoIngress: true
    slack:
      enabled: ${SLACK_ENABLED}
      botTokenSecretRef:
        name: platform-agent-secrets
        key: SLACK_BOT_TOKEN
      appTokenSecretRef:
        name: platform-agent-secrets
        key: SLACK_APP_TOKEN
      allowedUsers:
        - "${ALLOWED_USERS}"
