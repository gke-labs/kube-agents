# ==========================================
# Core Infrastructure
# ==========================================
PROJECT_ID="your-project-id"
REGION="us-central1"
CLUSTER_NAME="hermes-agent-cluster"
NAMESPACE="hermes"

# ==========================================
# Artifact Registry & Docker Build
# ==========================================
REPO_NAME="hermes-agent-repo"
IMAGE_NAME="hermes-agent"
IMAGE_TAG="latest"

# ==========================================
# Google Chat / PubSub Configuration
# ==========================================
CHAT_TOPIC_NAME="hermes-chat-events"
CHAT_SUB_NAME="hermes-chat-events-sub"
GSA_NAME="hermes-chat-bot"
KSA_NAME="hermes-chat-bot"

GOOGLE_CHAT_ALLOWED_USERS="your-email@google.com"
GOOGLE_CHAT_HOME_CHANNEL="" # Optional: Space to route initial messages

# ==========================================
# Secrets 
# ==========================================
GCP_API_KEY="your-gcp-api-key"
GEMINI_API_KEY="your-gemini-api-key"
