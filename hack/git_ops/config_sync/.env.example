# ==============================================================================
# GCP Config Sync Environment Variables Template (.env.example)
#
# Copy this file to a local '.env' file and fill in your details.
# WARNING: Do not commit the '.env' file to git. It is excluded in .gitignore.
# ==============================================================================

# Google Cloud Context
GCP_PROJECT_ID="your-gcp-project-id"
GKE_CLUSTER_NAME="kube-agents"
GKE_REGION="us-central1"
GKE_MEMBERSHIP_NAME="kube-agents-membership"
GKE_CONFIG_SYNC_VERSION="1.24.0"

# GitOps Repository Context
GIT_REPO_URL="https://github.com/your-username/kube-agents.git"
GIT_BRANCH="main"
GIT_SYNC_DIR="hack/git_ops/config_sync/manifests"
