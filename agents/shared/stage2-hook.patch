--- agents/original_stage2-hook.sh
+++ agents/modified_stage2-hook.sh
@@ -156,9 +156,23 @@
         s6-setuidgid hermes cp "$INSTALL_DIR/$src" "$HERMES_HOME/$dest"
     fi
 }
+# Initialize with defaults from /opt/defaults if SOUL.md is missing
+if [ ! -f "$HERMES_HOME/SOUL.md" ]; then
+    if [ -d "/opt/defaults" ]; then
+        echo "Initializing $HERMES_HOME with defaults from /opt/defaults..."
+        s6-setuidgid hermes cp -r /opt/defaults/. "$HERMES_HOME"/
+    fi
+fi
+
 seed_one ".env" ".env.example"
 seed_one "config.yaml" "cli-config.yaml.example"
-seed_one "SOUL.md" "docker/SOUL.md"
+
+# Inject GKE access token into config.yaml headers on container startup
+if [ -f "$HERMES_HOME/config.yaml" ]; then
+    echo "Injecting GCP access token into config.yaml..."
+    s6-setuidgid hermes /opt/hermes/.venv/bin/python3 -c 'import os, yaml, subprocess; exec("try:\n  token = subprocess.check_output([\"gcloud\", \"auth\", \"print-access-token\"]).decode().strip()\n  path = os.path.join(os.environ[\"HERMES_HOME\"], \"config.yaml\")\n  with open(path, \"r\") as f: cfg = yaml.safe_load(f) or {}\n  cfg.setdefault(\"mcp_servers\", {}).setdefault(\"developer_knowledge\", {})[\"headers\"] = {\"Authorization\": f\"Bearer {token}\"}\n  cfg[\"mcp_servers\"][\"developer_knowledge\"].pop(\"auth_provider_type\", None)\n  with open(path, \"w\") as f: yaml.safe_dump(cfg, f)\nexcept Exception as e:\n  print(f\"Warning: Token injection failed: {e}\")")'
+fi
 
